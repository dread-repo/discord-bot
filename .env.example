# Bot (required for src/index.ts)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: deploy slash commands to one guild (instant). Omit for global (slow).
# DISCORD_DEV_GUILD_ID=your_test_server_id

# Worker Thunderstore poll interval (ms). Default 600000 (10 min).
# THUNDERSTORE_POLL_INTERVAL_MS=600000

# Redis (docker-compose sets REDIS_URL for bot/worker)
REDIS_URL=redis://127.0.0.1:6379

# Supabase Postgres + Prisma
# Runtime: transaction pooler port 6543 with ?pgbouncer=true
DATABASE_URL=
# Migrations: direct db.<project-ref>.supabase.co:5432
DIRECT_URL=

# GitHub webhooks (spec 005) — worker HTTP on WEBHOOK_PORT (default 61952)
# Production: cloudflared → http://127.0.0.1:61952 (see specs/005-github-watcher/contracts/deployment-cloudflare-tunnel.md)
# GITHUB_WEBHOOK_SECRET=
# WEBHOOK_PORT=61952

# LLM (optional — no-op when unset)
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=
# LLM_DAILY_TOKEN_BUDGET=100000

# LOG_LEVEL=info
