# Discord (required)
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
# Guild-scoped command deploy target (recommended for development)
DISCORD_DEV_GUILD_ID=

# Redis (docker-compose default)
REDIS_URL=redis://redis:6379

# Supabase Postgres via Prisma (required)
# Supabase → Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler (port 6543) for bot/worker in production.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# GitHub webhooks (worker; optional until webhook server is exposed)
GITHUB_WEBHOOK_SECRET=
WEBHOOK_PORT=3000

# LLM (optional — no-op adapter when unset)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_DAILY_TOKEN_BUDGET=100000

# Dread in-character replies (0–1 probability per eligible message)
DREAD_REPLY_PROBABILITY=0.01

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Official Dread guild (hardcoded in app; documented for operators)
# OFFICIAL_GUILD_ID=1510452344024727775
